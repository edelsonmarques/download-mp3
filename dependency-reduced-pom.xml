<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <parent>
    <artifactId>spring-boot-starter-parent</artifactId>
    <groupId>org.springframework.boot</groupId>
    <version>3.5.15</version>
    <relativePath>pom.xml</relativePath>
  </parent>
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.kpitaine.os</groupId>
  <artifactId>yt-dlp-java</artifactId>
  <name>Yt-Dlp wrapper</name>
  <version>2.0.6</version>
  <description>Java wrapper for yt-dlp executable</description>
  <url>https://github.com/KpitaineSoftware/yt-dlp-java</url>
  <issueManagement>
    <system>GitHub</system>
    <url>https://github.com/KpitaineSoftware/yt-dlp-java/issues</url>
  </issueManagement>
  <developers>
    <developer>
      <id>sapher</id>
      <name>Xaser</name>
      <roles>
        <role>Initial developer</role>
      </roles>
    </developer>
    <developer>
      <id>jfposton</id>
      <name>Jonathan Poston</name>
      <roles>
        <role>initial developper</role>
      </roles>
    </developer>
    <developer>
      <id>damiencuvillier</id>
      <name>Damien Cuvillier</name>
      <email>damien@gotan.io</email>
      <url>https://damiencuvillier.com</url>
      <roles>
        <role>simple contributor, packager</role>
      </roles>
    </developer>
    <developer>
      <id>ericledevedec</id>
      <name>Eric Le Devedec</name>
      <email>eric.ledevedec@kpitaine.com</email>
      <url>https://kpitaine.com</url>
      <roles>
        <role>maintainer,developper</role>
      </roles>
    </developer>
  </developers>
  <licenses>
    <license>
      <name>WTFPL 2.0</name>
      <url>http://www.wtfpl.net/txt/copying/</url>
      <distribution>repo</distribution>
    </license>
  </licenses>
  <scm>
    <connection>scm:git@github.com:KpitaineSoftware/yt-dlp-java.git</connection>
    <developerConnection>scm:git:git@github.com:KpitaineSoftware/yt-dlp-java.git</developerConnection>
    <url>scm:git@github.com:KpitaineSoftware/yt-dlp-java.git</url>
  </scm>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
              <finalName>yt-dlp-java-${project.version}</finalName>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.4.2</version>
        <configuration>
          <archive>
            <manifest>
              <mainClass>com.jfposton.ytdlp.YtDlpMain</mainClass>
            </manifest>
          </archive>
        </configuration>
      </plugin>
    </plugins>
  </build>
  <dependencies>
    <dependency>
      <groupId>junit</groupId>
      <artifactId>junit</artifactId>
      <version>4.13.2</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-core</artifactId>
      <version>2.18.6</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-annotations</artifactId>
      <version>2.18.6</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
      <version>2.18.6</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.slf4j</groupId>
      <artifactId>slf4j-api</artifactId>
      <version>2.0.5</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
      <version>3.5.15</version>
      <scope>provided</scope>
    </dependency>
  </dependencies>
  <distributionManagement>
    <repository>
      <id>kpitaine-central</id>
      <name>Kpitaine Libraries</name>
      <url>https://repository.kpitaine.com/repository/maven-releases</url>
    </repository>
  </distributionManagement>
  <properties>
    <maven.compiler.target>17</maven.compiler.target>
    <maven.compiler.source>17</maven.compiler.source>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <jackson.version>2.18.6</jackson.version>
  </properties>
</project>
